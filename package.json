{
  "name": "attraction-kiosk",
  "version": "1.0.4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "build": {
    "appId": "com.epiland.kiosk",
    "productName": "Epiland-Kiosk",
    "artifactName": "Epiland-Kiosk-Setup-${version}.${ext}",
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "EvilMorff",
        "repo": "attraction-kiosk"
      }
    ]
  }
}